# HDA Vault Environment Configuration
# Copy this file to .env and fill in values as needed.
# All values have sensible defaults - most users don't need to change anything.

# ─── HDA Protocol Tuning ──────────────────────────────────────────
# Cell size for chunked processing (default: 50MB = 52428800 bytes)
# Larger = fewer cells, less overhead. Smaller = more granular progress.
# VITE_CELL_SIZE=52428800

# Header size reserved in HDA files (default: 2MB = 2097152 bytes)
# VITE_HEADER_SIZE=2097152

# Minimum dynamic header size for tiny archives (default: 32KB = 32768 bytes)
# VITE_MIN_HEADER_SIZE=32768

# PBKDF2 key derivation iterations (default: 600000)
# Higher = more secure but slower. OWASP recommends 600K+ for SHA-256.
# VITE_PBKDF2_ITERATIONS=600000

# Advisory threshold for memory fallback mode (default: 2GB = 2147483648 bytes)
# Top-level windows may continue above this if the browser can handle it.
# iframe/embed contexts still require direct-to-disk streaming beyond this threshold.
# VITE_MAX_FALLBACK_SIZE=2147483648

# ─── Development ──────────────────────────────────────────────────
# NODE_ENV is set automatically (development/production)
# VITE_LOG_LEVEL=info

# ─── Release / Diagnostics ───────────────────────────────────────
# Optional build trace override. CI sets this from the current commit SHA.
# VITE_GIT_SHA=dev

# Optional same-origin or self-hosted telemetry endpoints for opt-in diagnostics.
# The app only sends data when the user explicitly opts in.
# VITE_TELEMETRY_ENDPOINT=/api/telemetry
# VITE_ERROR_REPORT_ENDPOINT=/api/errors
